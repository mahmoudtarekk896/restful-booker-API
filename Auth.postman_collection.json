  "item": [
    {
      "name": "CreateToken",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responsejson= pm.response.json();\r",
              "var token= responsejson.token;\r",
              "console.log (token);\r",
              "pm.environment.set(\"EXTRACT TOKEN\", token);\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    });\r",
              "    pm.test(\"Token is not empty\", function () {\r",
              "        pm.expect(token).to.not.be.empty;\r",
              "        });\r",
              "        const schema = {\r",
              "  \"description\": \"\",\r",
              "  \"type\": \"object\",\r",
              "  \"properties\": {\r",
              "    \"token\": {\r",
              "      \"type\": \"string\",\r",
              "      \"minLength\": 1\r",
              "    }\r",
              "  },\r",
              "  \"required\": [\r",
              "    \"token\"\r",
              "  ]\r",
              "}\r",
              "pm.test(\"Response body is valid\", function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "    });\r",
              "    \r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\" : \"admin\",\n    \"password\" : \"password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base url}}/auth",
          "host": [
            "{{base url}}"
          ],
          "path": [
            "auth"
          ]
        }
      },
      "response": []
    }
  ]
